# Neon PostgreSQL (optionnel - l'app fonctionne en offline avec IndexedDB)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# --- Configuration IA ---
# Au moins une clé API est requise pour la saisie en langage naturel.
# Si les deux sont configurées, Anthropic est utilisé par défaut (sauf si AI_PROVIDER est défini).

# Anthropic API Key (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API Key (ChatGPT - alternative moins chère avec gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Choix du provider (optionnel) : "anthropic" ou "openai"
# Si non défini, utilise le provider dont la clé est configurée.
# AI_PROVIDER=openai
